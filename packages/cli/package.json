{
  "name": "odinfra",
  "version": "0.1.1",
  "description": "CLI for installing governed AI subagent setup files into existing projects.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "odinfra": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "opencode",
    "subagents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozkozturk/odinfra.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/ozkozturk/odinfra/issues"
  },
  "homepage": "https://github.com/ozkozturk/odinfra#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "pnpm --dir ../.. build && node dist/index.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@odinfra/generator": "workspace:*",
    "@odinfra/schema": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
