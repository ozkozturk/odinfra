{
  "name": "@odinfra/schema",
  "version": "0.1.2",
  "description": "Shared schema, role defaults, and permission presets for Odinfra packages.",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agents",
    "opencode",
    "schema",
    "subagents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozkozturk/odinfra.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/ozkozturk/odinfra/issues"
  },
  "homepage": "https://github.com/ozkozturk/odinfra#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node20"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
