{
  "name": "@odinfra/adapter-opencode",
  "version": "0.2.1",
  "description": "Render Odinfra agent configuration into OpenCode-compatible artifacts.",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agents",
    "opencode",
    "renderer",
    "subagents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozkozturk/odinfra.git",
    "directory": "packages/adapter-opencode"
  },
  "bugs": {
    "url": "https://github.com/ozkozturk/odinfra/issues"
  },
  "homepage": "https://github.com/ozkozturk/odinfra#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node20"
  },
  "dependencies": {
    "@odinfra/schema": "workspace:*",
    "@odinfra/templates": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  }
}
