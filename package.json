{
  "name": "odinfra-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm --recursive --sort run build",
    "changeset": "changeset",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm pack:check",
    "dev": "pnpm build && node packages/cli/dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:check": "node scripts/pack-check.mjs && tsc --project tsconfig.package-smoke.json",
    "release": "pnpm release:check",
    "release:check": "pnpm check && changeset status",
    "release:publish": "pnpm check && changeset publish",
    "release:trust": "node scripts/configure-npm-trusted-publishing.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
